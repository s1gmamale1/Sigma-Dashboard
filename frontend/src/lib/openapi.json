  "components": {
    "schemas": {
      "ChasePatchRequest": {
        "properties": {
          "chase_state": {
            "type": "string",
            "enum": [
              "none",
              "needs_chase",
              "chased",
              "resolved"
            ],
            "title": "Chase State"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "chase_state"
        ],
        "title": "ChasePatchRequest"
      },
      "Envelope": {
        "properties": {
          "data": {
            "title": "Data"
          },
          "meta": {
            "additionalProperties": true,
            "type": "object",
            "title": "Meta"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ErrorBody"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "Envelope"
      },
      "ErrorBody": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "details": {
            "additionalProperties": true,
            "type": "object",
            "title": "Details"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ErrorBody"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "username": {
            "type": "string",
            "maxLength": 120,
            "minLength": 1,
            "title": "Username"
          },
          "password": {
            "type": "string",
            "maxLength": 300,
            "minLength": 1,
            "title": "Password"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "title": "LoginRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "ViperAttendanceUpsert": {
        "properties": {
          "person": {
            "$ref": "#/components/schemas/ViperPersonRef"
          },
          "shift_date": {
            "type": "string",
            "format": "date",
            "title": "Shift Date"
          },
          "check_in_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Check In At"
          },
          "check_out_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Check Out At"
          },
          "status": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "in",
                  "late",
                  "charged",
                  "no_show",
                  "excused"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Status"
          },
          "chase_state": {
            "type": "string",
            "enum": [
              "none",
              "needs_chase",
              "chased",
              "resolved"
            ],
            "title": "Chase State",
            "default": "none"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "person",
          "shift_date"
        ],
        "title": "ViperAttendanceUpsert"
      },
      "ViperGoalUpsert": {
        "properties": {
          "slug": {
            "type": "string",
            "maxLength": 120,
            "minLength": 1,
            "title": "Slug"
          },
          "title": {
            "type": "string",
            "maxLength": 240,
            "minLength": 1,
            "title": "Title"
          },
          "owner_slug": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Owner Slug"
          },
          "topic_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Topic Id"
          },
          "deadline": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deadline"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "overdue",
              "done",
              "paused"
            ],
            "title": "Status",
            "default": "active"
          },
          "progress_percent": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Progress Percent",
            "default": 0
          },
          "last_update_at": {
            "anyOf": [
              {
